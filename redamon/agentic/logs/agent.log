- fs_write: {{"path": "relative path", "content": "string", "mode": "overwrite|create_only|append" (optional, default overwrite)}}
- fs_edit: {{"path": "relative path", "old_string": "exact match", "new_string": "replacement", "replace_all": bool (optional, default false)}}
- fs_multi_edit: {{"path": "relative path", "edits": [{"old_string": "...", "new_string": "...", "replace_all": bool}, ...]}}
- fs_undo_edit: {{"path": "relative path"}}
- fs_delete: {{"path": "relative path", "recursive": bool (optional, required for dirs)}}
- fs_move: {{"src": "relative source path", "dst": "relative destination path"}}
- fs_copy: {{"src": "relative source", "dst": "relative destination", "recursive": bool (optional, required for dirs)}}
- fs_mkdir: {{"path": "relative directory path", "parents": bool (optional, default true)}}
- fs_chmod: {{"path": "relative path", "mode_str": "octal (e.g. 755) or symbolic (+x, -w)"}}
- fs_symlink_create: {{"target": "relative path of the existing file", "linkname": "relative path of the link to create", "type": "soft|hard" (optional, default soft)}}
